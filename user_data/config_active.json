{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "bot_name": "botbot2-active",
  "dry_run": true,
  "dry_run_wallet": 10000,
  "max_open_trades": 10,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "position_adjustment_enable": false,
  "force_entry_enable": true,
  "initial_state": "running",
  "timeframe": "15m",
  "trading_mode": "futures",
  "margin_mode": "isolated",

  "unfilledtimeout": { "entry": 10, "exit": 10, "exit_timeout_count": 0, "unit": "minutes" },

  "entry_pricing": {
    "price_side": "same",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0.0,
    "check_depth_of_market": { "enabled": false, "bids_to_ask_delta": 1 }
  },
  "exit_pricing": { "price_side": "same", "use_order_book": true, "order_book_top": 1 },

  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "enable_ws": false,
    "ccxt_config": { "enableRateLimit": true },
    "ccxt_async_config": { "enableRateLimit": true },
    "pair_whitelist": [
      "BTC/USDT:USDT", "ETH/USDT:USDT", "SOL/USDT:USDT", "BNB/USDT:USDT", "XRP/USDT:USDT",
      "DOGE/USDT:USDT", "ADA/USDT:USDT", "AVAX/USDT:USDT", "LINK/USDT:USDT", "DOT/USDT:USDT",
      "LTC/USDT:USDT", "BCH/USDT:USDT", "NEAR/USDT:USDT", "APT/USDT:USDT", "ARB/USDT:USDT",
      "OP/USDT:USDT", "INJ/USDT:USDT", "ATOM/USDT:USDT", "UNI/USDT:USDT", "FIL/USDT:USDT"
    ],
    "pair_blacklist": [ ".*(BULL|BEAR|UP|DOWN)/.*", ".*(USDC|BUSD|TUSD|FDUSD|DAI)/.*" ]
  },

  "pairlists": [ { "method": "StaticPairList" } ],

  "telegram": { "enabled": false, "token": "", "chat_id": "" },

  "api_server": {
    "enabled": true,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": true,
    "jwt_secret_key": "PLACEHOLDER_override_via_env",
    "ws_token": "PLACEHOLDER_override_via_env",
    "CORS_origins": [],
    "username": "botbot2",
    "password": "PLACEHOLDER_override_via_env"
  },

  "internals": { "process_throttle_secs": 5 }
}
