{
  "$schema": "https://schema.freqtrade.io/schema.json",
  "bot_name": "botbot2-nfi-futures",
  "dry_run": true,
  "dry_run_wallet": 10000,
  "grinding_enable": true,
  "max_open_trades": 10,
  "stake_currency": "USDT",
  "stake_amount": "unlimited",
  "tradable_balance_ratio": 0.99,
  "fiat_display_currency": "USD",
  "available_capital": 10000,
  "position_adjustment_enable": true,
  "force_entry_enable": true,
  "initial_state": "running",
  "timeframe": "5m",
  "trading_mode": "futures",
  "margin_mode": "isolated",

  "nfi_parameters": {
    "futures_max_open_trades_long": 10,
    "futures_max_open_trades_short": 4,
    "futures_mode_leverage": 3.0,
    "futures_mode_leverage_rebuy_mode": 3.0,
    "futures_mode_leverage_grind_mode": 3.0
  },

  "unfilledtimeout": {
    "entry": 3,
    "exit": 2,
    "exit_timeout_count": 0,
    "unit": "minutes"
  },

  "order_types": {
    "entry": "limit",
    "exit": "limit",
    "emergency_exit": "limit",
    "force_entry": "limit",
    "force_exit": "limit",
    "stoploss": "limit",
    "stoploss_on_exchange": false,
    "stoploss_on_exchange_interval": 60,
    "stoploss_on_exchange_limit_ratio": 0.99
  },

  "entry_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0,
    "check_depth_of_market": { "enabled": false, "bids_to_ask_delta": 1 }
  },

  "exit_pricing": {
    "price_side": "other",
    "use_order_book": true,
    "order_book_top": 1,
    "price_last_balance": 0
  },

  "exchange": {
    "name": "binance",
    "key": "",
    "secret": "",
    "enable_ws": true,
    "ccxt_config": { "enableRateLimit": true },
    "ccxt_async_config": { "enableRateLimit": true },
    "pair_whitelist": [
      "BTC/USDT:USDT", "ETH/USDT:USDT", "SOL/USDT:USDT", "BNB/USDT:USDT", "XRP/USDT:USDT",
      "DOGE/USDT:USDT", "ADA/USDT:USDT", "AVAX/USDT:USDT", "LINK/USDT:USDT", "DOT/USDT:USDT",
      "LTC/USDT:USDT", "BCH/USDT:USDT", "NEAR/USDT:USDT", "APT/USDT:USDT", "ARB/USDT:USDT",
      "OP/USDT:USDT", "INJ/USDT:USDT", "ATOM/USDT:USDT", "UNI/USDT:USDT", "FIL/USDT:USDT",
      "ETC/USDT:USDT", "TRX/USDT:USDT", "SUI/USDT:USDT", "AAVE/USDT:USDT", "RUNE/USDT:USDT",
      "TIA/USDT:USDT", "SEI/USDT:USDT", "FET/USDT:USDT", "LDO/USDT:USDT", "ALGO/USDT:USDT"
    ],
    "pair_blacklist": [
      ".*(BULL|BEAR|UP|DOWN)/.*",
      ".*(USDC|BUSD|TUSD|FDUSD|DAI)/.*"
    ]
  },

  "pairlists": [ { "method": "StaticPairList" } ],

  "telegram": {
    "enabled": false,
    "token": "",
    "chat_id": "",
    "notification_settings": {
      "status": "on",
      "entry": "on",
      "entry_fill": "on",
      "exit": "on",
      "exit_fill": "on",
      "protection_trigger": "on"
    }
  },

  "api_server": {
    "enabled": true,
    "listen_ip_address": "127.0.0.1",
    "listen_port": 8080,
    "verbosity": "error",
    "enable_openapi": true,
    "jwt_secret_key": "PLACEHOLDER_override_via_env",
    "ws_token": "PLACEHOLDER_override_via_env",
    "CORS_origins": [],
    "username": "botbot2",
    "password": "PLACEHOLDER_override_via_env"
  },

  "internals": { "process_throttle_secs": 5 }
}
